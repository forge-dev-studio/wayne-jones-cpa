---
import SchemaOrg from './SchemaOrg.astro';
import { href, absoluteUrl } from '../lib/seo';

export interface Props {
  items: { label: string; href: string }[];
}

const { items } = Astro.props;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    item: absoluteUrl(item.href),
  })),
};
---
<nav aria-label="Breadcrumb" class="breadcrumbs">
  <ol class="breadcrumbs__list" role="list">
    {items.map((item, i) => (
      <li class="breadcrumbs__item">
        {i < items.length - 1 ? (
          <a href={href(item.href)} class="breadcrumbs__link">{item.label}</a>
        ) : (
          <span aria-current="page" class="breadcrumbs__current">{item.label}</span>
        )}
        {i < items.length - 1 && <span class="breadcrumbs__sep" aria-hidden="true">›</span>}
      </li>
    ))}
  </ol>
</nav>
<SchemaOrg schema={breadcrumbSchema} />
