---
// ServiceSchedule section — ported verbatim from site/index.html (6 rows hardcoded; Phase 2 refactors to content collection)
import { href } from '../../lib/seo';
---
<section id="services" class="services" aria-label="Schedule of services">
  <div class="section-wrap">
    <header class="section-head">
      <p class="eyebrow reveal" data-reveal>What we do</p>
      <h2 class="section-title reveal" data-reveal style="--d:1">Schedule of <em>Services</em></h2>
      <p class="section-deck reveal" data-reveal style="--d:2">Full-service accounting under one roof — set down plainly, the way a ledger should read.</p>
    </header>

    <div class="schedule-panel">
    <ol class="schedule" role="list">

      <li class="schedule__row reveal" data-reveal>
        <a class="schedule__link" href={href('/services/tax-preparation/')}>
          <span class="schedule__num" aria-hidden="true">I</span>
          <span class="schedule__body">
            <span class="schedule__title">Tax Preparation &amp; Planning</span>
            <span class="schedule__note">Accurate federal and state returns for businesses and individuals, with year-round planning to keep your tax bill as low as the law allows.</span>
          </span>
          <span class="schedule__rule" aria-hidden="true"></span>
          <span class="schedule__folio" aria-hidden="true">&rarr;</span>
        </a>
      </li>

      <li class="schedule__row reveal" data-reveal style="--d:1">
        <a class="schedule__link" href={href('/services/bookkeeping/')}>
          <span class="schedule__num" aria-hidden="true">II</span>
          <span class="schedule__body">
            <span class="schedule__title">Bookkeeping &amp; Monthly Write-Up</span>
            <span class="schedule__note">Clean, current books every month — reconciliations, financial statements, and the numbers you need to run your business.</span>
          </span>
          <span class="schedule__rule" aria-hidden="true"></span>
          <span class="schedule__folio" aria-hidden="true">&rarr;</span>
        </a>
      </li>

      <li class="schedule__row reveal" data-reveal style="--d:2">
        <a class="schedule__link" href={href('/services/payroll/')}>
          <span class="schedule__num" aria-hidden="true">III</span>
          <span class="schedule__body">
            <span class="schedule__title">Payroll &amp; HR</span>
            <span class="schedule__note">Dependable payroll processing, filings, and HR support so your team is paid right and on time.</span>
          </span>
          <span class="schedule__rule" aria-hidden="true"></span>
          <span class="schedule__folio" aria-hidden="true">&rarr;</span>
        </a>
      </li>

      <li class="schedule__row reveal" data-reveal style="--d:3">
        <a class="schedule__link" href={href('/services/irs-tax-resolution/')}>
          <span class="schedule__num" aria-hidden="true">IV</span>
          <span class="schedule__body">
            <span class="schedule__title">IRS &amp; Tax-Problem Resolution</span>
            <span class="schedule__note">Behind on filings or facing a notice? We deal with the IRS and the Georgia DOR on your behalf.</span>
          </span>
          <span class="schedule__rule" aria-hidden="true"></span>
          <span class="schedule__folio" aria-hidden="true">&rarr;</span>
        </a>
      </li>

      <li class="schedule__row reveal" data-reveal style="--d:4">
        <a class="schedule__link" href={href('/services/business-consulting/')}>
          <span class="schedule__num" aria-hidden="true">V</span>
          <span class="schedule__body">
            <span class="schedule__title">Business Consulting</span>
            <span class="schedule__note">Entity setup, cash flow, and growth decisions — practical advice from a CPA who knows small business.</span>
          </span>
          <span class="schedule__rule" aria-hidden="true"></span>
          <span class="schedule__folio" aria-hidden="true">&rarr;</span>
        </a>
      </li>

      <li class="schedule__row reveal" data-reveal style="--d:5">
        <a class="schedule__link" href={href('/services/individual-tax-returns/')}>
          <span class="schedule__num" aria-hidden="true">VI</span>
          <span class="schedule__body">
            <span class="schedule__title">Individual Tax Returns</span>
            <span class="schedule__note">Personal returns handled with care — including investments, retirement, and major life changes.</span>
          </span>
          <span class="schedule__rule" aria-hidden="true"></span>
          <span class="schedule__folio" aria-hidden="true">&rarr;</span>
        </a>
      </li>

    </ol>
    </div>
  </div>
</section>
