---
// LedgerBar section — ported verbatim from site/index.html
---
<section class="ledgerbar" aria-label="At a glance">
  <div class="ledgerbar__inner">
    <div class="hairline hairline--draw" data-rule role="separator"></div>
    <div class="ledgerbar__panel">
    <dl class="ledgerbar__row">
      <div class="ledgerbar__stat reveal" data-reveal>
        <dt class="ledgerbar__num" data-count data-to="2008" data-format="plain">2008</dt>
        <dd class="ledgerbar__lbl">Serving Rome since</dd>
      </div>
      <div class="ledgerbar__stat reveal" data-reveal style="--d:1">
        <dt class="ledgerbar__num"><span data-count data-to="35" data-format="plain">35</span><em>+</em></dt>
        <dd class="ledgerbar__lbl">Years of experience</dd>
      </div>
      <div class="ledgerbar__stat reveal" data-reveal style="--d:2">
        <dt class="ledgerbar__num ledgerbar__num--word">GA <em>&amp;</em> AL</dt>
        <dd class="ledgerbar__lbl">Licensed in two states</dd>
      </div>
      <div class="ledgerbar__stat reveal" data-reveal style="--d:3">
        <dt class="ledgerbar__num ledgerbar__num--word">CPA <span data-count data-to="026715" data-pad="6" data-format="plain">026715</span></dt>
        <dd class="ledgerbar__lbl">Georgia license</dd>
      </div>
    </dl>
    </div>
    <div class="hairline hairline--draw" data-rule role="separator"></div>
  </div>
</section>
