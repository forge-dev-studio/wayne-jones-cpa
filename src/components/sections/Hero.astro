---
// Hero section — ported verbatim from site/index.html
---
<section id="hero" class="hero" aria-label="Introduction">
  <div class="hero__wrap">

    <!-- Guilloché backdrop -->
    <svg class="guilloche-bg" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
      <use href="#guilloche"></use>
    </svg>

    <div class="hero__grid">
      <!-- Left — editorial -->
      <div class="hero__left">
        <p class="hero__eyebrow reveal" data-reveal style="--d:0">Certified Public Accountant — Rome, Georgia</p>
        <h1 class="hero__h1 reveal-clip" data-reveal-lines>
          <span class="line"><span class="line__inner">Rome's most</span></span>
          <span class="line"><span class="line__inner">trusted <em>name</em></span></span>
          <span class="line"><span class="line__inner">in tax &amp;</span></span>
          <span class="line"><span class="line__inner">accounting.</span></span>
        </h1>
        <div class="hero__pull reveal" data-reveal style="--d:4">
          <p class="hero__sub">Personal, year-round CPA service for small businesses and individuals across Georgia and Alabama — with the same hand on every return since 2008.</p>
        </div>
        <div class="hero__ctas reveal" data-reveal style="--d:5">
          <a href="#contact" class="btn-primary">Request a Consultation</a>
          <a href="tel:+17062328565" class="btn-ghost">(706) 232-8565</a>
        </div>
      </div>

      <!-- Right — engraved ledger / certificate -->
      <aside class="hero__right reveal" data-reveal style="--d:5" aria-label="Credentials at a glance">
        <div class="ledger__seal-wrap">
          <svg width="100" height="100" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Wayne Jones, CPA — seal">
            <use href="#wj-seal"></use>
          </svg>
        </div>
        <div class="ledger__lines">
          <div class="ledger__line">
            <span class="ledger__label">License No.</span>
            <span class="ledger__value">GA #026715</span>
          </div>
          <div class="ledger__line">
            <span class="ledger__label">Jurisdictions</span>
            <span class="ledger__value">Georgia <em>&amp;</em> Alabama</span>
          </div>
          <div class="ledger__line">
            <span class="ledger__label">Experience</span>
            <span class="ledger__value">35+ Years</span>
          </div>
          <div class="ledger__line">
            <span class="ledger__label">Specialties</span>
            <span class="ledger__value">Tax <em>&amp;</em> Small Business</span>
          </div>
          <div class="ledger__line">
            <span class="ledger__label">Location</span>
            <span class="ledger__value">Rome, Georgia</span>
          </div>
        </div>
        <div class="ledger__est">
          <span class="ledger__est-text">Established</span>
          <span class="ledger__est-year">2008</span>
        </div>
      </aside>
    </div>
  </div>
</section>
