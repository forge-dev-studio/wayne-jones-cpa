<section id="who" class="register" aria-label="Who we serve">
  <!-- PLACEHOLDER: confirm industry specialties with owner -->
  <div class="section-wrap register__grid">
    <div class="register__statement reveal" data-reveal>
      <p class="eyebrow">Who we serve</p>
      <h2 class="section-title">Built for Rome's small businesses — <em>and the people behind them.</em></h2>
      <p class="lead">From Main Street shops and contractors to professional practices and growing startups, Wayne Jones Accounting Services handles the books, payroll, and taxes so you can focus on your business. Individuals get that same personal attention at tax time and all year long.</p>
    </div>
    <ul class="register__list reveal" data-reveal style="--d:1" role="list">
      <li class="register__item"><span class="register__check" aria-hidden="true"></span><span class="register__entry">Small businesses &amp; LLCs</span></li>
      <li class="register__item"><span class="register__check" aria-hidden="true"></span><span class="register__entry">Sole proprietors &amp; contractors</span></li>
      <li class="register__item"><span class="register__check" aria-hidden="true"></span><span class="register__entry">Professional practices</span></li>
      <li class="register__item"><span class="register__check" aria-hidden="true"></span><span class="register__entry">Startups &amp; new ventures</span></li>
      <li class="register__item"><span class="register__check" aria-hidden="true"></span><span class="register__entry">Individuals &amp; families</span></li>
    </ul>
  </div>
</section>
