---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTASection from '../components/CTASection.astro';

const seo = {
  title: 'Privacy Policy | Wayne Jones, CPA — Rome, GA',
  description:
    'How Wayne Jones, CPA collects and uses information submitted through this website.',
  canonical: '/privacy/',
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Privacy', href: '/privacy/' },
];
---

<BaseLayout seo={seo}>
  <Breadcrumbs items={breadcrumbs} />

  <section class="legal-page" aria-label="Privacy policy">
    <div class="section-wrap section-wrap--prose">
      <header class="section-head">
        <p class="eyebrow reveal" data-reveal>Legal</p>
        <h1 class="section-title reveal" data-reveal style="--d:1">Privacy <em>Policy</em></h1>
        <p class="section-deck reveal" data-reveal style="--d:2">Last updated: June 6, 2026</p>
      </header>

      <div class="legal-prose reveal" data-reveal style="--d:3">
        <h2>Information we collect</h2>
        <p>We collect only the information you choose to give us through our contact form: your name, email address, phone number, the service you're interested in, and any message you write. We do not require you to create an account.</p>

        <h2>How the form works</h2>
        <p>Our contact form is processed by a third-party provider, Formspree, which delivers your message to us by email. We use the information solely to respond to your inquiry and, if you become a client, to provide the services you request.</p>

        <h2>No tracking</h2>
        <p>This website does not use advertising cookies, analytics trackers, or pixels. We load web fonts from Google Fonts, and our contact page embeds a Google Map; your browser contacts Google to load these, subject to Google's privacy practices.</p>

        <h2>Sensitive information</h2>
        <p>Please do not send Social Security numbers, financial-account numbers, or tax documents through the website form. Contact our office directly to share sensitive information securely.</p>

        <h2>Confidentiality of client information</h2>
        <p>Information you provide in the course of a professional engagement is protected under the confidentiality standards that apply to Certified Public Accountants.</p>

        <h2>Sharing</h2>
        <p>We do not sell your information. We do not share it except as needed to respond to you, to provide services you request, or as required by law.</p>

        <h2>Your choices</h2>
        <p>To ask what information we hold or to request deletion of a form submission, contact us at (706) 232-8565.</p>

        <h2>Changes</h2>
        <p>We may update this policy; the 'last updated' date above will reflect any changes.</p>

        <h2>Contact</h2>
        <p>Wayne Jones Accounting Services, 101 East 2nd Avenue, Suite 330, Rome, GA 30161 · (706) 232-8565.</p>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .legal-page { padding-top: clamp(48px, 6vw, 80px); padding-bottom: clamp(40px, 5vw, 64px); }
  .legal-prose { margin-top: 32px; }
  .legal-prose h2 { font-family: var(--font-display); font-weight: 500; font-size: 1.2rem; color: var(--ink); margin: 28px 0 8px; }
  .legal-prose h2:first-child { margin-top: 0; }
  .legal-prose p { font-family: var(--font-body); font-weight: 300; font-size: 0.97rem; line-height: 1.7; color: var(--ink-muted); max-width: 72ch; margin: 0 0 1em; }
</style>
