---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTASection from '../../components/CTASection.astro';
import FaqList from '../../components/FaqList.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { href, absoluteUrl } from '../../lib/seo';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await service.render();
const d = service.data;

const seo = {
  title: d.metaTitle,
  description: d.metaDescription,
  canonical: `/services/${service.slug}/`,
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services/' },
  { label: d.title, href: `/services/${service.slug}/` },
];

// Fetch related service entries for cross-links
const allServices = await getCollection('services');
const relatedEntries = allServices.filter((s) =>
  d.relatedServices.includes(s.slug),
);

// Service JSON-LD
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: d.title,
  serviceType: d.serviceType,
  description: d.metaDescription,
  provider: {
    '@type': 'AccountingService',
    '@id': absoluteUrl('/') + '#business',
  },
  areaServed: [
    { '@type': 'State', name: 'Georgia' },
    { '@type': 'State', name: 'Alabama' },
  ],
  url: absoluteUrl(`/services/${service.slug}/`),
};
---

<BaseLayout seo={seo}>
  <SchemaOrg schema={serviceSchema} />
  <Breadcrumbs items={breadcrumbs} />

  <article class="service-detail section-wrap" aria-label={d.title}>

    <!-- Hero heading -->
    <header class="service-detail__header">
      <p class="eyebrow reveal" data-reveal>{d.serviceType}</p>
      <h1 class="section-title reveal" data-reveal style="--d:1">{d.h1}</h1>
      <p class="section-deck reveal" data-reveal style="--d:2">{d.summary}</p>
    </header>

    <!-- Prose body (MDX/MD content) -->
    {/* Content is empty for now; renders nothing when there's no body prose */}
    <div class="service-detail__body prose reveal" data-reveal style="--d:3">
      <Content />
    </div>

    <!-- What's included -->
    {d.whatsIncluded.length > 0 && (
      <div class="service-detail__included reveal" data-reveal>
        <h2 class="service-detail__subhead">What's included</h2>
        <ul class="service-detail__list">
          {d.whatsIncluded.map((item) => (
            <li class="service-detail__list-item">{item}</li>
          ))}
        </ul>
      </div>
    )}

    <!-- Who it's for -->
    {d.whoItsFor && (
      <div class="service-detail__for reveal" data-reveal>
        <h2 class="service-detail__subhead">Who it's for</h2>
        <p class="service-detail__for-text">{d.whoItsFor}</p>
      </div>
    )}

    <!-- FAQ -->
    {d.faq.length > 0 && (
      <div class="service-detail__faq">
        <h2 class="service-detail__subhead reveal" data-reveal>
          Frequently Asked Questions
        </h2>
        <FaqList items={d.faq} />
      </div>
    )}

    <!-- Related services -->
    {relatedEntries.length > 0 && (
      <div class="service-detail__related reveal" data-reveal>
        <h2 class="service-detail__subhead">Related Services</h2>
        <ul class="service-detail__related-list">
          {relatedEntries.map((s) => (
            <li>
              <a
                href={href(`/services/${s.slug}/`)}
                class="service-detail__related-link"
              >
                {s.data.title} &rarr;
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

  </article>

  <CTASection />
</BaseLayout>

<style>
  .service-detail {
    padding-top: clamp(48px, 6vw, 80px);
    padding-bottom: clamp(48px, 6vw, 80px);
  }

  .service-detail__header {
    margin-bottom: clamp(40px, 5vw, 64px);
  }

  .service-detail__body {
    margin-bottom: clamp(40px, 5vw, 56px);
  }

  .service-detail__subhead {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.3rem, 2.1vw, 1.8rem);
    color: var(--ink);
    letter-spacing: -0.015em;
    margin: 0 0 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(182, 146, 74, 0.38);
  }

  .service-detail__included,
  .service-detail__for,
  .service-detail__faq,
  .service-detail__related {
    margin-bottom: clamp(40px, 5vw, 56px);
  }

  .service-detail__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .service-detail__list-item {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.97rem;
    line-height: 1.7;
    color: var(--ink-muted);
    padding: 10px 0 10px 28px;
    border-bottom: 1px solid rgba(182, 146, 74, 0.15);
    position: relative;
  }

  .service-detail__list-item::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 1.2rem;
    line-height: 1.5;
  }

  .service-detail__for-text {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.97rem;
    line-height: 1.7;
    color: var(--ink-muted);
    max-width: 72ch;
    margin: 0;
  }

  .service-detail__related-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .service-detail__related-link {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--oxblood);
    text-decoration: none;
    border: 1px solid rgba(182, 146, 74, 0.38);
    padding: 8px 18px;
    transition: background 0.25s var(--ease), color 0.25s var(--ease);
  }

  .service-detail__related-link:hover {
    background: var(--oxblood);
    color: var(--ivory);
  }

  /* Basic prose styling for MDX content */
  .prose :global(p) {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.97rem;
    line-height: 1.7;
    color: var(--ink-muted);
    max-width: 72ch;
    margin: 0 0 1.2em;
  }

  .prose :global(h2),
  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.015em;
    margin: 1.5em 0 0.5em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 0.97rem;
    line-height: 1.7;
    color: var(--ink-muted);
    padding-left: 1.5em;
    margin: 0 0 1.2em;
  }
</style>
