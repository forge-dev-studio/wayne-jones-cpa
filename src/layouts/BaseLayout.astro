---
import Seo from '../components/Seo.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCallBar from '../components/StickyCallBar.astro';
import '../styles/global.css';
import { SITE } from '../config';
import { absoluteUrl } from '../lib/seo';

export interface Props {
  seo: {
    title: string;
    description: string;
    canonical?: string;
    ogImage?: string;
    noindex?: boolean;
    type?: string;
  };
}

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'AccountingService',
  name: SITE.name,
  legalName: SITE.legalName,
  '@id': absoluteUrl('/') + '#business',
  url: absoluteUrl('/'),
  telephone: SITE.phone,
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.street,
    addressLocality: SITE.city,
    addressRegion: SITE.state,
    postalCode: SITE.zip,
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE.lat,
    longitude: SITE.lng,
  },
  openingHours: SITE.openingHoursSpec,
  areaServed: SITE.areaServed,
  founder: {
    '@type': 'Person',
    name: 'Wayne Jones',
    jobTitle: 'Certified Public Accountant',
  },
  sameAs: [SITE.facebook],
};
---
<!doctype html>
<html lang="en" class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking fonts: load async via media=print swap, with a <noscript> fallback -->
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400;1,9..144,500&family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,300;1,9..144,400;1,9..144,500&family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet" />
    </noscript>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Seo {...Astro.props.seo} />
    <SchemaOrg schema={orgSchema} />
  </head>
  <body>
    <!-- Shared inline SVG defs (guilloché + WJ wax seal), reused via <use> -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
      <defs>
        <g id="guilloche">
          <g transform="translate(300,300)" fill="none" stroke="currentColor">
            <circle r="295" stroke-width="1"/>
            <circle r="288" stroke-width="0.5"/>
            <circle r="280" stroke-width="0.5"/>
            <g>
              <ellipse rx="260" ry="30" stroke-width="0.6"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(15)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(30)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(45)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(60)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(75)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(90)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(105)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(120)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(135)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(150)"/>
              <ellipse rx="260" ry="30" stroke-width="0.6" transform="rotate(165)"/>
            </g>
            <g>
              <ellipse rx="180" ry="22" stroke-width="0.5"/>
              <ellipse rx="180" ry="22" stroke-width="0.5" transform="rotate(20)"/>
              <ellipse rx="180" ry="22" stroke-width="0.5" transform="rotate(40)"/>
              <ellipse rx="180" ry="22" stroke-width="0.5" transform="rotate(60)"/>
              <ellipse rx="180" ry="22" stroke-width="0.5" transform="rotate(80)"/>
              <ellipse rx="180" ry="22" stroke-width="0.5" transform="rotate(100)"/>
              <ellipse rx="180" ry="22" stroke-width="0.5" transform="rotate(120)"/>
              <ellipse rx="180" ry="22" stroke-width="0.5" transform="rotate(140)"/>
              <ellipse rx="180" ry="22" stroke-width="0.5" transform="rotate(160)"/>
            </g>
            <g>
              <ellipse rx="110" ry="16" stroke-width="0.4"/>
              <ellipse rx="110" ry="16" stroke-width="0.4" transform="rotate(18)"/>
              <ellipse rx="110" ry="16" stroke-width="0.4" transform="rotate(36)"/>
              <ellipse rx="110" ry="16" stroke-width="0.4" transform="rotate(54)"/>
              <ellipse rx="110" ry="16" stroke-width="0.4" transform="rotate(72)"/>
              <ellipse rx="110" ry="16" stroke-width="0.4" transform="rotate(90)"/>
              <ellipse rx="110" ry="16" stroke-width="0.4" transform="rotate(108)"/>
              <ellipse rx="110" ry="16" stroke-width="0.4" transform="rotate(126)"/>
              <ellipse rx="110" ry="16" stroke-width="0.4" transform="rotate(144)"/>
              <ellipse rx="110" ry="16" stroke-width="0.4" transform="rotate(162)"/>
            </g>
            <circle r="55" stroke-width="0.5"/>
            <circle r="46" stroke-width="0.4"/>
            <circle r="38" stroke-width="0.35"/>
            <circle r="28" stroke-width="0.4"/>
            <circle r="18" stroke-width="0.35"/>
            <circle r="10" stroke-width="0.4"/>
          </g>
        </g>
        <g id="wj-seal">
          <circle cx="50" cy="50" r="47" fill="none" stroke="#B6924A" stroke-width="1.2"/>
          <circle cx="50" cy="50" r="43" fill="none" stroke="#B6924A" stroke-width="0.5"/>
          <circle cx="50" cy="50" r="40" fill="none" stroke="#B6924A" stroke-width="0.35"/>
          <circle cx="50" cy="50" r="36.5" fill="none" stroke="#B6924A" stroke-width="0.5"/>
          <circle cx="50" cy="50" r="35" fill="var(--seal-fill, #F7F4EC)"/>
          <circle cx="50" cy="50" r="33" fill="none" stroke="#B6924A" stroke-width="0.3" stroke-dasharray="1.8 1.8"/>
          <g stroke="#B6924A" stroke-width="0.6">
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(0,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(15,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(30,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(45,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(60,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(75,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(90,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(105,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(120,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(135,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(150,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(165,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(180,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(195,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(210,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(225,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(240,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(255,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(270,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(285,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(300,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(315,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="8" transform="rotate(330,50,50)"/>
            <line x1="50" y1="3.5" x2="50" y2="7" transform="rotate(345,50,50)"/>
          </g>
          <text x="50" y="58" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-weight="600" font-size="22" fill="var(--seal-ink, #122036)" letter-spacing="2">WJ</text>
          <text x="50" y="68.5" text-anchor="middle" font-family="Spectral, Georgia, serif" font-weight="300" font-size="5.5" fill="#B6924A" letter-spacing="3">CPA</text>
        </g>
      </defs>
    </svg>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <StickyCallBar />
    <script src="../scripts/engraved.js"></script>
  </body>
</html>
